# filter-repo replacement rules for the public mirror.
#
# Used for BOTH --replace-text (blob content) and --replace-message
# (commit messages) in .github/workflows/public-mirror.yml. The same
# file drives both passes.
#
# COMMENTS ARE SAFE HERE ONLY BECAUSE OF A STRIPPING STEP. Before
# git filter-repo reads this file, the workflow keeps only real rule
# lines via an ALLOW-LIST grep
# (grep -E '^(literal:|regex:|glob:)') to produce
# replacements.clean.txt, and points filter-repo at that cleaned copy.
# git filter-repo --replace-text does NOT itself skip `#` lines: a bare
# `#` line fed directly to filter-repo parses as the literal rule
# `# -> ***REMOVED***`, corrupting every `#` in every mirrored file
# (shebangs, comments, markdown headings). That was the bug in
# issue #157.
#
# EVERY RULE MUST CARRY AN EXPLICIT PREFIX: literal:, regex:, or glob:.
# The workflow keeps ONLY lines that start with one of those prefixes,
# which is what drops comments and blank lines. It is also precisely
# what lets a rule's match-text safely BEGIN with `#`: a deny-list
# (grep -v '^#') would wrongly strip `literal:#foo==>bar`, but the
# allow-list keeps it because the line starts with `literal:`. A rule
# line WITHOUT one of these prefixes is silently dropped and will not
# take effect — always prefix.
#
# So: do NOT remove the stripping step in the workflow, and do NOT
# point filter-repo directly at this file.
#
# ORDERING MATTERS: filter-repo applies replacements in file order.
# Compound strings (full cluster names, full <RoleName>-<AccountID>
# SSO profiles) MUST be listed before any prefix or substring that
# would also match them. The blanket prose sweeps for the bare
# "ExampleProject" / "example-" tokens come LAST so the specific
# compound identifiers above are matched first and only residual
# prose occurrences reach those rules.

# Personal paths
literal:/path/to/repo/==>/path/to/repo/
literal:/Users/<user>/==>/Users/<user>/

# Cross-account IAM role
literal:ExampleCrossAccountRole==>ExampleCrossAccountRole

# IAM Identity Center SSO profiles (full <RoleName>-<AccountID> form)
literal:ExampleManagementAdmin-ACCOUNT==>ExampleManagementAdmin-ACCOUNT
literal:ExampleInfrastructureAdmin-ACCOUNT==>ExampleInfrastructureAdmin-ACCOUNT
literal:ExampleDevOpsAdmin-ACCOUNT==>ExampleDevOpsAdmin-ACCOUNT
literal:ExampleSandboxAdmin-ACCOUNT==>ExampleSandboxAdmin-ACCOUNT
literal:ExampleIntegAdmin-ACCOUNT==>ExampleIntegAdmin-ACCOUNT
literal:ExampleQaAdmin-ACCOUNT==>ExampleQaAdmin-ACCOUNT
literal:ExampleProdAdmin-ACCOUNT==>ExampleProdAdmin-ACCOUNT

# Bare AWS account IDs (catches any occurrences outside the
# SSO-profile form, e.g. ARNs, bare references)
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED
literal:REDACTED==>REDACTED

# EKS cluster
literal:example-cluster==>example-cluster

# Repo and org names
literal:example-app-repo==>example-app-repo
literal:example-infra-repo==>example-infra-repo
literal:example-claude-app==>example-claude-app
literal:example-other-repo==>example-other-repo
literal:github.com/example-org/==>github.com/example-org/
literal:example-org/repo==>example-org/repo

# ExampleProject token in prose (must come AFTER all compound forms above)
literal:ExampleProject==>ExampleProject
literal:example-==>example-
